$host = "zimalofo.mysql.db.internal";  // "rv9w2f.myd.infomaniak.com";
$db   = "your_db_name";        // Change to your DB name, eg. "rv9w2f_blabla"
$user = "your_db_user_name";   // "rv9w2f_jan";   // Change to your DB user
$pass = "IM4_Physco_26";       // Change to your DB pass if needed

try {
    $dsn = "mysql:host=$host;dbname=$db;charset=utf8mb4";
    $pdo = new PDO($dsn, $user, $pass);
    // Optional: Set error mode
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
} catch (Exception $e) {
    echo "Database connection error: " . $e->getMessage();
    exit;
}
